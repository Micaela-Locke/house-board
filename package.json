{
  "name": "hib",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "sst dev",
    "deploy": "sst deploy",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "ci:verify": "npm run lint && npm run test && npm run typecheck"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.0.0",
    "prettier": "^3.5.3",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "sst": "^4.3.5"
  }
}
